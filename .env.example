# Kalshi API credentials (optional — public read API works without key for discovery)
# Get your API key at https://kalshi.com/sign-up → Settings → API
KALSHI_API_KEY=your_key_here

# Demo mode — use simulated Kalshi data (no API key needed)
DEMO_MODE=true

# Poll interval in milliseconds (default: 3000)
POLL_INTERVAL_MS=3000

# How often to re-run full discovery/matching across the entire universe.
# Refresh cycles only update quotes for already-matched pairs.
DISCOVERY_INTERVAL_CYCLES=10

# Minimum profit percentage to surface an opportunity (default: 0.8)
MIN_PROFIT_PCT=0.8

# If true, MIN_PROFIT_PCT applies to profit after estimated taker fees (see *_TAKER_FEE_BPS).
MIN_PROFIT_USES_NET=false

# Estimated taker fees (basis points per leg) for net profit display / filter
POLY_TAKER_FEE_BPS=50
KALSHI_TAKER_FEE_BPS=30

# Minimum combined volume in USD to consider a market (default: 1000)
MIN_VOLUME_USD=1000

# Minimum fuzzy match score to consider two markets equivalent (default: 0.70)
MATCH_THRESHOLD=0.70

# Minimum shared normalized tokens for candidate Kalshi↔Poly pairs (default: 2)
MIN_SHARED_TOKENS=2

# If true, skip pairs where both titles contain years but no year overlaps
MATCHER_YEAR_GATE=true

# Maximum difference in close dates to consider matching (default: 7)
MAX_CLOSE_DATE_DELTA_DAYS=7

# Polymarket Gamma API — token bucket (max burst / sustained RPS)
POLYMARKET_PAGE_SIZE=500
POLYMARKET_BUCKET_MAX=10
POLYMARKET_BUCKET_REFILL_RPS=10

# Kalshi public API page size + adaptive rate (RPS)
KALSHI_PAGE_SIZE=200
KALSHI_RATE_MIN_RPS=1.5
KALSHI_RATE_MAX_RPS=4
KALSHI_ADAPTIVE_SUCCESS_BEFORE_BUMP=25
KALSHI_ADAPTIVE_BUMP_RPS=0.25
KALSHI_ADAPTIVE_DECAY_ON429=0.75

# Discovery caps (initial scan can be slower; refresh should be fast)
POLYMARKET_DISCOVERY_MAX_PAGES=60
POLYMARKET_CONDITION_IDS_BATCH_SIZE=200
KALSHI_EVENTS_DISCOVERY_MAX_PAGES=20
KALSHI_MAX_EVENTS_DISCOVERY=300
KALSHI_MARKETS_MAX_PAGES_PER_EVENT_DISCOVERY=3
KALSHI_MARKETS_MAX_PAGES_PER_EVENT_REFRESH=10

# HTTP request timeout in milliseconds (default: 5000)
REQUEST_TIMEOUT_MS=5000

# Rolling window for p50/p95 cycle latency in metrics.log
METRICS_ROLLING_CYCLES=60
